# Copy to .env.local and fill in.
#
# Mint an inherit token from the CLI (edit-capable; the chat endpoint requires
# edit, so a plain `--role member` key would 403):
#   pagespace keys create --drive <driveId> --name support-demo --show-token
#
# The demo has two audiences (toggle in the header when your drive role is
# OWNER/ADMIN):
#   Visitor — chats with the PUBLIC (read-only) agent through the server-side
#             proxy, and browses/searches the docs. Holds no edit power.
#   Admin   — chats with the OWNER (write-capable) agent to edit the docs, and
#             gets the Manage tab. Uses your own token.

# --- Client (exposed to the browser via Vite) ---

# Token the app uses for the SDK (docs browsing; and admin editing when your
# drive role is OWNER/ADMIN). For a real PUBLIC deploy, use a read-only token
# here and don't ship the admin UI.
VITE_PAGESPACE_TOKEN=mcp_your_token_here
VITE_PAGESPACE_DRIVE_ID=v7neoikqnqi883n83me303en

# Public (read-only) agent — customers chat with this.
VITE_PAGESPACE_PUBLIC_AGENT_ID=lmd2bh2cq36kamaaxo97ix5p
# Owner (write-capable) agent — owners "vibe their docs" with this in Admin view.
VITE_PAGESPACE_OWNER_AGENT_ID=f8pshy5q4mrmgvzmdricm2x0

VITE_PAGESPACE_BOT_NAME=PageSpace
# Optional API base (defaults: same-origin dev proxy / https://pagespace.ai).
# VITE_PAGESPACE_API_URL=

# --- Server only (NOT exposed to the browser) ---

# The public chat is proxied through the dev server so customers never hold an
# edit token (edit also lets you reconfigure the agent — enable bash, etc.). This
# token stays server-side; the proxy pins it to the public agent and forwards
# only chat-completions. In production this is a serverless function, and rate
# limiting lives here (the endpoint has none natively).
PAGESPACE_PROXY_TOKEN=mcp_your_token_here
PAGESPACE_PUBLIC_AGENT_ID=lmd2bh2cq36kamaaxo97ix5p
