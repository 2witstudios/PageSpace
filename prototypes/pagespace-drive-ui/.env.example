# Copy to .env.local and fill in.
#
# Mint tokens from the CLI (an inherit key — the chat endpoint needs edit
# access, so a plain `--role member` key would 403):
#   pagespace keys create --drive <driveId> --name support-demo --show-token
#
# A "public" visitor token and an "admin" token can be the same edit-capable
# key here; the Manage tab is shown only when the token's drive role is
# OWNER/ADMIN. For a real public deployment, proxy the chat server-side and
# add rate limiting (the endpoint has none natively).

# The mcp_ token the demo runs on.
VITE_PAGESPACE_TOKEN=mcp_your_token_here

# Optional. Defaults: same-origin in dev (Vite proxies /api to pagespace.ai),
# https://pagespace.ai in prod.
# VITE_PAGESPACE_API_URL=

# Optional. Defaults to the first drive the token can see.
VITE_PAGESPACE_DRIVE_ID=v7neoikqnqi883n83me303en

# Optional. Defaults to the first AI_CHAT page in the drive.
VITE_PAGESPACE_AGENT_ID=lmd2bh2cq36kamaaxo97ix5p

# Shown in the header / empty state.
VITE_PAGESPACE_BOT_NAME=PageSpace
