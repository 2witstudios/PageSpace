# Database
DATABASE_URL=postgresql://user:password@localhost:5432/pagespace

# Port
PORT=3001

# CORS — the web app's public URL(s)
CORS_ORIGIN=http://localhost:3000
# ADDITIONAL_ALLOWED_ORIGINS=https://example.com,https://another.example.com

# Sentry Error Monitoring — server-only (realtime has no client bundle).
# In production (cloud/tenant), SENTRY_DSN is required — requireSentryDsn()
# fails loud at boot without it. Onprem deployments are exempt.
SENTRY_DSN=
SENTRY_SEND_DEFAULT_PII=
