# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/pagespace

# Session auth (must match web app)
CSRF_SECRET=change-me-min-32-chars-long-secret

# Stripe (cloud deployments only)
STRIPE_SECRET_KEY=sk_test_...

# URLs
ADMIN_URL=http://localhost:3005
NEXT_PUBLIC_WEB_APP_URL=http://localhost:3000

# Email (for magic link login)
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@yourapp.com

# Global prompt proxy (admin app proxies to web app for the global prompt viewer)
# WEB_APP_INTERNAL_URL is the server-to-server URL (e.g. http://web:3000 in Docker)
WEB_APP_INTERNAL_URL=http://localhost:3000
SERVICE_API_SECRET=change-me-min-32-chars-long-service-secret
