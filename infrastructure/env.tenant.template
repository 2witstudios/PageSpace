# PageSpace Tenant Environment Template
# Generate a complete .env with: ./scripts/generate-tenant-env.sh <slug>

# --- Tenant Identity ---
TENANT_SLUG=__SET_BY_PROVISIONER__

# --- Image Config ---
IMAGE_TAG=latest

# --- Deployment Mode ---
DEPLOYMENT_MODE=tenant

# --- Database ---
POSTGRES_DB=pagespace
POSTGRES_USER=pagespace
POSTGRES_PASSWORD=__GENERATE__

# --- Security Secrets ---
ENCRYPTION_KEY=__GENERATE__
CSRF_SECRET=__GENERATE__
JWT_SECRET=__GENERATE__
JWT_ISSUER=pagespace
JWT_AUDIENCE=pagespace-users
CRON_SECRET=__GENERATE__
REALTIME_BROADCAST_SECRET=__GENERATE__
REDIS_PASSWORD=__GENERATE__

# --- Application URLs (derived from TENANT_SLUG) ---
WEB_APP_URL=__SET_BY_PROVISIONER__
CORS_ORIGIN=__SET_BY_PROVISIONER__
NEXT_PUBLIC_APP_URL=__SET_BY_PROVISIONER__

# --- Storage Config ---
STORAGE_DEFAULT_QUOTA_MB=500
STORAGE_MAX_FILE_SIZE_MB=20
STORAGE_MAX_CONCURRENT_UPLOADS=5
STORAGE_MIN_FREE_MEMORY_MB=500
STORAGE_ENABLE_QUOTAS=true
NEXT_PUBLIC_STORAGE_MAX_FILE_SIZE_MB=20

# --- Processor Config ---
ENABLE_OCR=false
ENABLE_EXTERNAL_OCR=false
PROCESSOR_AUTH_REQUIRED=true
PROCESSOR_UPLOAD_RATE_LIMIT=100
PROCESSOR_UPLOAD_RATE_WINDOW=3600

# --- AI Providers (optional) ---
GOOGLE_AI_DEFAULT_API_KEY=
