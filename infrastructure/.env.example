# Traefik Reverse Proxy Environment Variables
# Copy to .env and fill in values before starting Traefik.

# Cloudflare API token for DNS-01 ACME challenge (wildcard cert issuance).
# Create at https://dash.cloudflare.com/profile/api-tokens with Zone:DNS:Edit permission.
CF_DNS_API_TOKEN=

# Traefik dashboard basic auth credentials (htpasswd format).
# Generate with: echo $(htpasswd -nB admin) | sed -e 's/\$/\$\$/g'
# The double-dollar escaping is required for Docker Compose.
TRAEFIK_DASHBOARD_AUTH=
