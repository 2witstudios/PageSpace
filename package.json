{
  "name": "pagespace-local",
  "private": true,
  "license": "UNLICENSED",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo dev --filter=!control-plane",
    "dev:atlas": "bun --filter 'atlas' run dev",
    "dev:db": "docker compose up postgres migrate seed -d",
    "dev:services": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up postgres processor realtime -d",
    "build": "turbo build",
    "build:atlas": "bun --filter 'atlas' run build",
    "lint": "turbo lint",
    "lint:scripts": "eslint --config scripts/eslint.config.mjs scripts",
    "typecheck": "turbo typecheck",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun --filter '@pagespace/db' run db:migrate",
    "test": "./scripts/test-with-db.sh",
    "test:turbo": "turbo run test",
    "test:unit": "bun --filter '@pagespace/lib' run test && cd apps/web && npx vitest run",
    "test:watch": "bun --filter '@pagespace/lib' run test -- --watch",
    "test:ui": "bun --filter '@pagespace/lib' run test -- --ui",
    "test:coverage": "turbo run test:coverage",
    "coverage:report": "node scripts/coverage-report.mjs",
    "coverage:ratchet": "node scripts/coverage-ratchet.mjs",
    "test:scripts": "echo 'Script tests require isolated vitest context. Run: bun --cwd packages/db x tsx ../../scripts/verify-token-migration.ts' && exit 1",
    "verify:migrations": "bun --cwd packages/db x tsx ../../scripts/verify-token-migration.ts",
    "dev:desktop": "bun --filter 'desktop' run dev",
    "build:desktop": "bun --filter 'desktop' run build",
    "package:desktop": "bun --filter 'desktop' run package",
    "check:fetch": "node scripts/check-fetch-auth.js",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "changelog:generate": "npx tsx scripts/changelog/index.ts",
    "test:infra": "cd infrastructure && npx vitest run",
    "test:infra:runtime": "cd infrastructure && npx vitest run scripts/__tests__/image-runtime.test.ts --timeout 120000",
    "test:security": "./scripts/test-security.sh",
    "setup:admin": "tsx scripts/setup-onprem-admin.ts"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.3.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.13",
    "@typescript-eslint/typescript-estree": "^8.46.0",
    "eslint": "^9.36.0",
    "typescript-eslint": "^8.59.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.0",
    "@vitest/ui": "^2.1.0",
    "dotenv": "^17.2.0",
    "drizzle-kit": "^0.23.2",
    "jsdom": "^25.0.1",
    "knip": "^5.70.2",
    "msw": "^2.6.8",
    "tsx": "^4.21.0",
    "turbo": "^2.5.5",
    "typescript": "^5.8.3",
    "vitest": "^2.1.0",
    "yaml": "^2.8.2"
  },
  "packageManager": "bun@1.3.12",
  "overrides": {
    "drizzle-orm": "^0.32.2",
    "react": "^19.1.2",
    "react-dom": "^19.1.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "mdast-util-to-hast": "^13.2.1",
    "@react-email/preview-server>next": "16.2.6"
  },
  "trustedDependencies": [
    "@tensorflow/tfjs-node",
    "core-js",
    "electron",
    "electron-winstaller",
    "esbuild",
    "msw",
    "sharp",
    "tesseract.js",
    "unrs-resolver",
    "web"
  ]
}
