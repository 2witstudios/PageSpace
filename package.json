{
  "name": "pagespace-local",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22"
  },
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo dev --filter=!control-plane",
    "dev:atlas": "bun run --filter 'atlas' dev",
    "dev:db": "docker compose up postgres migrate seed -d",
    "dev:services": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up postgres processor realtime -d",
    "build": "turbo build",
    "build:atlas": "bun run --filter 'atlas' build",
    "lint": "turbo lint",
    "lint:scripts": "eslint --config scripts/eslint.config.mjs scripts",
    "typecheck": "turbo typecheck",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run --filter '@pagespace/db' db:migrate",
    "db:generate:admin": "bun run --filter '@pagespace/db' db:generate:admin",
    "db:migrate:admin": "bun run --filter '@pagespace/db' db:migrate:admin",
    "db:provision:admin-users": "bun run --filter '@pagespace/db' db:provision:admin-users",
    "test": "./scripts/test-with-db.sh",
    "test:turbo": "turbo run test",
    "test:unit": "turbo run test --filter=@pagespace/lib && bun run --filter 'web' test",
    "test:watch": "bun run --filter '@pagespace/lib' test -- --watch",
    "test:ui": "bun run --filter '@pagespace/lib' test -- --ui",
    "test:coverage": "turbo run test:coverage",
    "coverage:report": "node scripts/coverage-report.mjs",
    "coverage:ratchet": "node scripts/coverage-ratchet.mjs",
    "dev:desktop": "bun run --filter 'desktop' dev",
    "build:desktop": "bun run --filter 'desktop' build",
    "package:desktop": "bun run --filter 'desktop' package",
    "check:fetch": "node scripts/check-fetch-auth.js",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "knip:check": "node scripts/knip-ratchet.mjs",
    "knip:ratchet": "node scripts/knip-ratchet.mjs --write",
    "changelog:generate": "npx tsx scripts/changelog/index.ts",
    "test:infra": "cd infrastructure && bunx vitest run",
    "test:infra:runtime": "cd infrastructure && bunx vitest run scripts/__tests__/image-runtime.test.ts --timeout 120000",
    "test:security": "./scripts/test-security.sh",
    "setup:admin": "bun scripts/setup-onprem-admin.ts",
    "promote-admin": "bun scripts/promote-admin.ts"
  },
  "devDependencies": {
    "@pagespace/db": "workspace:*",
    "@pagespace/lib": "workspace:*",
    "@paralleldrive/cuid2": "^2.2.2",
    "@faker-js/faker": "^9.3.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.13",
    "@typescript-eslint/typescript-estree": "^8.46.0",
    "eslint": "^9.36.0",
    "typescript-eslint": "^8.59.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.0",
    "@vitest/ui": "^2.1.0",
    "dotenv": "^17.2.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "jsdom": "^25.0.1",
    "knip": "^5.70.2",
    "msw": "^2.6.8",
    "pg": "^8.16.3",
    "@types/pg": "^8.15.4",
    "tsx": "^4.21.0",
    "turbo": "^2.5.5",
    "typescript": "^5.8.3",
    "vitest": "^2.1.0",
    "yaml": "^2.8.2"
  },
  "packageManager": "bun@1.3.12",
  "overrides": {
    "drizzle-orm": "^0.45.2",
    "react": "^19.1.2",
    "react-dom": "^19.1.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "mdast-util-to-hast": "^13.2.1"
  },
  "trustedDependencies": [
    "@tensorflow/tfjs-node",
    "core-js",
    "electron",
    "electron-winstaller",
    "esbuild",
    "msw",
    "sharp",
    "tesseract.js",
    "unrs-resolver"
  ]
}
