# ============================================================================
# PageSpace On-Premise Deployment Configuration
# ============================================================================
# Copy this file to .env and fill in the required values.
# Lines starting with # are comments. Uncomment and set values as needed.

# ---------------------------------------------------------------------------
# Deployment Mode (REQUIRED)
# ---------------------------------------------------------------------------
DEPLOYMENT_MODE=onprem
NEXT_PUBLIC_DEPLOYMENT_MODE=onprem

# ---------------------------------------------------------------------------
# Database (REQUIRED)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://pagespace:your_strong_password@localhost:5432/pagespace

# ---------------------------------------------------------------------------
# Security Secrets (REQUIRED - generate unique values for each)
# ---------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=generate_a_64_char_hex_string_here
SESSION_SECRET=generate_another_64_char_hex_string_here
CSRF_SECRET=generate_another_64_char_hex_string_here
CRON_SECRET=generate_another_64_char_hex_string_here

# ---------------------------------------------------------------------------
# Application URLs (REQUIRED)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://pagespace.clinic.local
NEXTAUTH_URL=https://pagespace.clinic.local
REALTIME_URL=wss://pagespace.clinic.local

# ---------------------------------------------------------------------------
# Cookie Domain (set to your on-prem domain for cross-subdomain cookies)
# ---------------------------------------------------------------------------
# COOKIE_DOMAIN=.clinic.local
# NEXT_PUBLIC_COOKIE_DOMAIN=.clinic.local

# ---------------------------------------------------------------------------
# AI providers (deployment-managed — per-user BYOK is not supported)
# ---------------------------------------------------------------------------
# All users share whatever the operator configures here. Providers without
# their env vars set are hidden from the model picker. On-prem allows only
# the local + BAA-friendly providers below; cloud-only providers (Anthropic,
# OpenAI, xAI, OpenRouter, etc.) are blocked at the route layer regardless.

# Ollama (local LLM runtime — recommended for on-prem)
OLLAMA_BASE_URL=http://localhost:11434

# LM Studio (alternative local runtime)
# LMSTUDIO_BASE_URL=http://localhost:1234/v1

# Azure OpenAI (BAA-covered cloud AI). Both vars must be set for the provider
# to appear; the endpoint URL is SSRF-validated at request time.
# AZURE_OPENAI_API_KEY=your_azure_api_key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/openai/deployments/your-deployment/

# ---------------------------------------------------------------------------
# Session & HIPAA Compliance
# ---------------------------------------------------------------------------
# Idle session timeout in milliseconds (default: 15 minutes for on-prem)
# SESSION_IDLE_TIMEOUT_MS=900000

# AI usage log retention in days (default: 90)
# AI_LOG_RETENTION_DAYS=90

# ---------------------------------------------------------------------------
# File Storage
# ---------------------------------------------------------------------------
# Local filesystem path for uploaded files
FILE_STORAGE_PATH=./data/files

# ---------------------------------------------------------------------------
# Services
# ---------------------------------------------------------------------------
# Realtime service (Socket.IO)
REALTIME_PORT=3001

# Processor service (file processing)
PROCESSOR_PORT=3003
PROCESSOR_URL=http://localhost:3003

# ---------------------------------------------------------------------------
# NOT NEEDED for on-prem (these are cloud-only):
# ---------------------------------------------------------------------------
# STRIPE_SECRET_KEY          (billing disabled)
# STRIPE_WEBHOOK_SECRET      (billing disabled)
# GOOGLE_CLIENT_ID           (OAuth disabled)
# GOOGLE_CLIENT_SECRET       (OAuth disabled)
# APPLE_CLIENT_ID            (OAuth disabled)
# APPLE_CLIENT_SECRET        (OAuth disabled)
# RESEND_API_KEY             (email disabled)
# BRAVE_API_KEY              (web search optional)
